---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DocsBody from '@/components/DocsBody.astro';
import { defaultLocale } from '@/lib/i18n';
import { getPageContent } from '@/lib/content';
import type { PageFrontmatter } from '@/lib/content-types';

const locale = defaultLocale;
const { content } = getPageContent<PageFrontmatter>(locale, 'docs');
const { frontmatter } = content;
const Content = content.Content as unknown as () => unknown;
---
<BaseLayout locale={locale} title={frontmatter.title} description={frontmatter.description} currentPath="/docs">
  <DocsBody locale={locale} title={frontmatter.title}>
    <Content />
  </DocsBody>
</BaseLayout>

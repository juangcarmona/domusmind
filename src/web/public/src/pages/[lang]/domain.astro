---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionBlock from '@/components/SectionBlock.astro';
import { locales, normalizeLocale } from '@/lib/i18n';
import { getContent } from '@/lib/content';
import type { SectionContent, SectionsPageContent } from '@/lib/content-types';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = normalizeLocale(Astro.params.lang);
const content = getContent<SectionsPageContent>(locale, 'domain');
---
<BaseLayout locale={locale} title={content.title} description={content.description} currentPath="/domain">
  <h1>{content.title}</h1>
  {content.sections.map((section: SectionContent) => <SectionBlock section={section} />)}
</BaseLayout>

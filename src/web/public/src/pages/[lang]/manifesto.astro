---
import '@/styles/pages.css';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import PageCtaBlock from '@/components/PageCtaBlock.astro';
import FallbackNotice from '@/components/FallbackNotice.astro';
import { locales, defaultLocale, normalizeLocale } from '@/lib/i18n';
import { getPageContent } from '@/lib/content';
import type { ManifestoFrontmatter } from '@/lib/content-types';

export function getStaticPaths() {
  return locales.filter((l) => l !== defaultLocale).map((lang) => ({ params: { lang } }));
}

const locale = normalizeLocale(Astro.params.lang);
const { content, sourceLocale } = getPageContent<ManifestoFrontmatter>(locale, 'manifesto-page');
const isFallback = sourceLocale !== locale;
const { frontmatter } = content;
---
<BaseLayout
  locale={locale}
  title={frontmatter.title}
  description={frontmatter.description}
  currentPath="/manifesto"
  mainClass="page-main"
>
  <PageHero headline={frontmatter.hero.headline} supportLine={frontmatter.hero.supportLine} />

  <div class="page-body">
    {isFallback && <FallbackNotice locale={locale} />}

    <section class="page-section">
      <div class="manifesto-blocks">
        {frontmatter.blocks.map((block) => (
          <div class="manifesto-block">
            <h2 class="manifesto-block__title">{block.title}</h2>
            <p class="manifesto-block__body">{block.body}</p>
          </div>
        ))}
      </div>
    </section>

    <p class="manifesto-closing">{frontmatter.closing}</p>

    <PageCtaBlock section={frontmatter.cta} locale={locale} />
  </div>
</BaseLayout>

---
import '@/styles/homepage.css';
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/HeroSection.astro';
import RealitySection from '@/components/RealitySection.astro';
import BreakdownSection from '@/components/BreakdownSection.astro';
import ShiftSection from '@/components/ShiftSection.astro';
import ProofSection from '@/components/ProofSection.astro';
import HowItWorksSection from '@/components/HowItWorksSection.astro';
import CurrentStateSection from '@/components/CurrentStateSection.astro';
import EarlyAccessSection from '@/components/EarlyAccessSection.astro';
import FallbackNotice from '@/components/FallbackNotice.astro';
import { locales, defaultLocale, normalizeLocale } from '@/lib/i18n';
import { getPageContent } from '@/lib/content';
import type { HomeFrontmatter } from '@/lib/content-types';

export function getStaticPaths() {
  return locales.filter((l) => l !== defaultLocale).map((lang) => ({ params: { lang } }));
}

const locale = normalizeLocale(Astro.params.lang);
const { content, sourceLocale } = getPageContent<HomeFrontmatter>(locale, 'home');
const isFallback = sourceLocale !== locale;
const { frontmatter } = content;
---
<BaseLayout
  locale={locale}
  title={frontmatter.title}
  description={frontmatter.description}
  currentPath="/"
  headerCta={frontmatter.hero.primaryCta}
  mainClass="homepage-main"
>
  <div class="homepage">
    <HeroSection content={frontmatter.hero} locale={locale} />
    {isFallback && <FallbackNotice locale={locale} />}
    <RealitySection section={frontmatter.reality} />
    <BreakdownSection section={frontmatter.breakdown} />
    <ShiftSection section={frontmatter.shift} />
    <ProofSection section={frontmatter.proof} />
    <HowItWorksSection section={frontmatter.howItWorks} />
    <CurrentStateSection section={frontmatter.currentState} />
    <EarlyAccessSection section={frontmatter.earlyAccess} locale={locale} />
  </div>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { locales, normalizeLocale, withLocale } from '@/lib/i18n';
import { getPageContent } from '@/lib/content';
import type { PageFrontmatter } from '@/lib/content-types';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = normalizeLocale(Astro.params.lang);
const { content, sourceLocale } = getPageContent<PageFrontmatter>(locale, 'community');
if (sourceLocale !== locale) {
  return Astro.redirect(withLocale(sourceLocale, '/community'));
}
const { frontmatter } = content;
const Content = content.Content as unknown as () => unknown;
---
<BaseLayout locale={locale} title={frontmatter.title} description={frontmatter.description} currentPath="/community">
  <h1>{frontmatter.title}</h1>
  <Content />
  <p><a class="button" href="https://github.com/juangcarmona/Domus-Mind">GitHub</a></p>
</BaseLayout>

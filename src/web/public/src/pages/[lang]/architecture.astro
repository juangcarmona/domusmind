---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArchitectureBody from '@/components/ArchitectureBody.astro';
import { locales, defaultLocale, normalizeLocale } from '@/lib/i18n';
import { getPageContent } from '@/lib/content';
import type { PageFrontmatter } from '@/lib/content-types';

export function getStaticPaths() {
  return locales.filter((l) => l !== defaultLocale).map((lang) => ({ params: { lang } }));
}

const locale = normalizeLocale(Astro.params.lang);
const { content, sourceLocale } = getPageContent<PageFrontmatter>(locale, 'architecture');
const isFallback = sourceLocale !== locale;
const { frontmatter } = content;
const Content = content.Content as unknown as () => unknown;
---
<BaseLayout locale={locale} title={frontmatter.title} description={frontmatter.description} currentPath="/architecture">
  <ArchitectureBody locale={locale} title={frontmatter.title} isFallback={isFallback}>
    <Content />
  </ArchitectureBody>
</BaseLayout>

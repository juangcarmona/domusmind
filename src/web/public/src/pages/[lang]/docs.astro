---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { locales, normalizeLocale, withLocale } from '@/lib/i18n';
import { getPageContent } from '@/lib/content';
import type { PageFrontmatter } from '@/lib/content-types';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = normalizeLocale(Astro.params.lang);
const { content, sourceLocale } = getPageContent<PageFrontmatter>(locale, 'docs');
if (sourceLocale !== locale) {
  return Astro.redirect(withLocale(sourceLocale, '/docs'));
}
const { frontmatter } = content;
const Content = content.Content as unknown as () => unknown;
---
<BaseLayout locale={locale} title={frontmatter.title} description={frontmatter.description} currentPath="/docs">
  <h1>{frontmatter.title}</h1>
  <Content />
  <p>
    <a href={withLocale(locale, '/domain')}>Domain</a> ·
    <a href={withLocale(locale, '/open-source')}>Open Source</a>
  </p>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionBlock from '@/components/SectionBlock.astro';
import { locales, normalizeLocale, withLocale } from '@/lib/i18n';
import { getContent } from '@/lib/content';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = normalizeLocale(Astro.params.lang);
const content = getContent(locale, 'docs') as any;
---
<BaseLayout locale={locale} title={content.title} description={content.description} currentPath="/docs">
  <h1>{content.title}</h1>
  {content.sections.map((section: any) => <SectionBlock section={section} />)}
  <ul>
    {content.links.map((link: any) => (
      <li><a href={link.href}>{link.label}</a></li>
    ))}
  </ul>
  <p>
    <a href={withLocale(locale, '/domain')}>Domain</a> ·
    <a href={withLocale(locale, '/open-source')}>Open Source</a>
  </p>
</BaseLayout>

---
import FallbackNotice from './FallbackNotice.astro';
import GitHubIcon from './GitHubIcon.astro';
import type { Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
  title: string;
  isFallback?: boolean;
}

const { locale, title, isFallback = false } = Astro.props;
---
<article class="page-action" data-page-type="community">
  {isFallback && <FallbackNotice locale={locale} />}
  <h1>{title}</h1>
  <slot />
  <section class="community-cta" aria-label="GitHub">
    <a class="button github-button" href="https://github.com/juangcarmona/domusmind" target="_blank" rel="noopener noreferrer">
      <GitHubIcon size={16} />
      GitHub Repository
    </a>
  </section>
</article>

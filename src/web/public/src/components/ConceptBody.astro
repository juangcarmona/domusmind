---
import FallbackNotice from './FallbackNotice.astro';
import { withLocale, type Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
  title: string;
  isFallback?: boolean;
}

const { locale, title, isFallback = false } = Astro.props;
---
<article class="page-explanatory" data-page-type="concept">
  {isFallback && <FallbackNotice locale={locale} />}
  <h1>{title}</h1>
  <slot />
  <nav class="page-next" aria-label="Continue">
    <a href={withLocale(locale, '/community')}>Follow the project &rarr;</a>
    <a href={withLocale(locale, '/architecture')}>Read the architecture &rarr;</a>
  </nav>
</article>

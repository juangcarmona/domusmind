---
import { withLocale, type Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
  primaryCta: { label: string; href: string };
  secondaryCta: { label: string; href: string };
}

const { locale, primaryCta, secondaryCta } = Astro.props;

type Data = {
  recognition: { lines: string[]; anchor: string };
  reframe:     string[];

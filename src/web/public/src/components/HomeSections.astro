const data = content[locale] ?? content['en'];
---

<div class="home-sections">

  <section class="home-section recognition-section">
    {data.recognition.lines.map(l => <p>{l}</p>)}
    <p class="recognition-anchor">{data.recognition.anchor}</p>
  </section>

  <section class="home-section reframe-section">
    {data.reframe.map(l => <p>{l}</p>)}
  </section>

  <section class="home-section solution-section">
    <p class="solution-line">{data.solution}</p>
  </section>

  <section class="home-section">
    <div class="today-preview">
      <p class="today-preview__heading">{data.today.heading}</p>
      <div class="today-preview__body">
        {data.today.groups.map(group => (
          <div class="today-preview__group">
            {group.map(line => <span class="today-preview__line">{line}</span>)}
          </div>
        ))}
      </div>
    </div>
    <p class="today-caption">{data.today.caption}</p>
  </section>

  <section class="home-section">
    <h2 class="section-heading">{data.changes.heading}</h2>
    <ul class="changes-list">
      {data.changes.items.map(item => <li>{item}</li>)}
    </ul>
  </section>

  <section class="home-section action-section-home">
    <a class="button cta-dominant" href={withLocale(locale, primaryCta.href)}>
      {primaryCta.label}
    </a>
    <a class="cta-secondary-weak" href={withLocale(locale, secondaryCta.href)}>
      {secondaryCta.label}
    </a>
  </section>

</div>

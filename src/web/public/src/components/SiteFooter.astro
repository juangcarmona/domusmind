---
import type { Locale } from '@/lib/i18n';
import type { UiContent } from '@/lib/content-types';
import GitHubIcon from './GitHubIcon.astro';

const { locale: _locale, ui } = Astro.props as { locale: Locale; ui: UiContent };
---
<footer class="site-footer">
  <p class="site-footer__meta"><strong>{ui.siteName}</strong> <span>{ui.tagline}</span></p>
  <ul>
    <li>
      <a class="footer-github" href="https://github.com/juangcarmona/domusmind" aria-label="GitHub repository" target="_blank" rel="noopener noreferrer">
        <GitHubIcon size={14} />
        {ui.footer.github}
      </a>
    </li>
  </ul>
</footer>

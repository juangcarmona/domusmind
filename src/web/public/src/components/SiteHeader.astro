---
import type { Locale } from '@/lib/i18n';
import { withLocale } from '@/lib/i18n';
import type { LinkContent, UiContent } from '@/lib/content-types';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';

const { locale, ui, currentPath = '/', primaryCta } = Astro.props as {
  locale: Locale;
  ui: UiContent;
  currentPath?: string;
  primaryCta?: LinkContent;
};

const navLinks = [
  { label: 'How it works', href: '/how-it-works' },
  { label: 'Mental load', href: '/mental-load' },
  { label: 'Manifesto', href: '/manifesto' },
  { label: 'Early access', href: '/early-access' },
];

function isActive(href: string): boolean {
  return currentPath === href || currentPath.startsWith(href + '/');
}
---
<header class="site-header">
  <a class="brand" href={withLocale(locale, '/')}>
    <svg class="brand-mark" viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <polygon fill="currentColor" points="128,24 24,112 24,232 232,232 232,112"/>
      <rect fill="currentColor" x="172" y="52" width="20" height="44"/>
      <polygon fill="var(--surface)" points="60,216 60,112 128,168 196,112 196,216 164,216 164,166 128,220 92,166 92,216"/>
    </svg>
    {ui.siteName}
  </a>
  <button class="nav-menu-toggle" id="nav-menu-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="header-nav">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
      <line x1="3" y1="6" x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
  </button>
  <nav class="header-nav" id="header-nav" aria-label="Main navigation">
    {navLinks.map((link) => (
      <a
        class="header-nav__link"
        href={withLocale(locale, link.href)}
        aria-current={isActive(link.href) ? 'page' : undefined}
      >{link.label}</a>
    ))}
  </nav>
  <div class="header-controls">
    {primaryCta && (
      <a class="button button--compact" href={withLocale(locale, primaryCta.href)}>
        {primaryCta.label}
      </a>
    )}
    <LanguageSwitcher locale={locale} path={currentPath} label={ui.languageLabel} />
    <ThemeToggle label={ui.themeLabel} />
  </div>
</header>
<script>
  const toggle = document.getElementById('nav-menu-toggle');
  const nav = document.getElementById('header-nav');
  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const open = nav.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(open));
    });
  }
</script>

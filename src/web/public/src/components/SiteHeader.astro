---
import type { Locale } from '@/lib/i18n';
import { withLocale } from '@/lib/i18n';
import type { UiContent } from '@/lib/content-types';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';
import GitHubIcon from './GitHubIcon.astro';

const { locale, ui, currentPath = '/' } = Astro.props as {
  locale: Locale;
  ui: UiContent;
  currentPath?: string;
};

const links = [
  { key: 'home', href: '/' },
  { key: 'manifesto', href: '/manifesto' },
  { key: 'concept', href: '/concept' },
  { key: 'architecture', href: '/architecture' },
  { key: 'community', href: '/community' },
  { key: 'docs', href: '/docs' },
];
---
<header class="site-header">
  <a class="brand" href={withLocale(locale, '/')}>
    <svg class="brand-mark" viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <polygon fill="currentColor" points="128,24 24,112 24,232 232,232 232,112"/>
      <rect fill="currentColor" x="172" y="52" width="20" height="44"/>
      <polygon fill="var(--surface)" points="60,216 60,112 128,168 196,112 196,216 164,216 164,166 128,220 92,166 92,216"/>
    </svg>
    {ui.siteName}
  </a>
  <button class="nav-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false">
    <span></span>
    <span></span>
    <span></span>
  </button>
  <nav aria-label="Primary" class="primary-nav">
    <ul>
      {links.map((link) => (
        <li>
          <a href={withLocale(locale, link.href)} aria-current={currentPath === link.href ? 'page' : undefined}>
            {ui.nav[link.key]}
          </a>
        </li>
      ))}
    </ul>
  </nav>
  <div class="header-controls">
    <a
      class="icon-link"
      href="https://github.com/juangcarmona/domusmind"
      aria-label="GitHub repository"
      target="_blank"
      rel="noopener noreferrer"
    >
      <GitHubIcon size={18} />
    </a>
    <LanguageSwitcher locale={locale} path={currentPath} label={ui.languageLabel} />
    <ThemeToggle label={ui.themeLabel} />
  </div>
</header>

<script is:inline>
  const siteHeader = document.querySelector('.site-header');
  const navToggle = siteHeader?.querySelector('.nav-toggle');
  const navMenu = siteHeader?.querySelector('.primary-nav');
  const mobileMediaQuery = window.matchMedia('(max-width: 768px)');

  const closeNavMenu = () => {
    navToggle?.setAttribute('aria-expanded', 'false');
    navMenu?.classList.remove('is-open');
  };

  const toggleNavMenu = () => {
    const isExpanded = navToggle?.getAttribute('aria-expanded') === 'true';
    navToggle?.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
    navMenu?.classList.toggle('is-open', !isExpanded);
  };

  navToggle?.addEventListener('click', () => {
    if (!mobileMediaQuery.matches) return;
    toggleNavMenu();
  });

  navMenu?.addEventListener('click', (event) => {
    if (!mobileMediaQuery.matches) return;
    const target = event.target;
    if (target instanceof Element && target.closest('a')) {
      closeNavMenu();
    }
  });

  document.addEventListener('click', (event) => {
    if (!mobileMediaQuery.matches) return;
    const target = event.target;
    if (target instanceof Node && !siteHeader?.contains(target)) {
      closeNavMenu();
    }
  });

  mobileMediaQuery.addEventListener('change', () => {
    if (!mobileMediaQuery.matches) {
      closeNavMenu();
    }
  });
</script>

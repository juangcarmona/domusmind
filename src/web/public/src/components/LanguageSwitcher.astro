---
import { locales, type Locale, withLocale } from '@/lib/i18n';

const { locale, path = '/' } = Astro.props as { locale: Locale; path?: string };
const localeNames: Record<Locale, string> = {
  en: 'English',
  es: 'Español',
  fr: 'Français',
  de: 'Deutsch',
  it: 'Italiano',
  zh: '中文',
  ja: '日本語',
};
---
<label class="sr-only" for="locale-switcher">{Astro.props.label ?? 'Language'}</label>
<select
  id="locale-switcher"
  class="locale-select"
  aria-label={Astro.props.label ?? 'Language'}
  onChange="window.location.href = this.value"
>
  {locales.map((candidate) => (
    <option value={withLocale(candidate, path)} selected={candidate === locale}>{localeNames[candidate]}</option>
  ))}
</select>

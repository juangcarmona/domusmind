---
import { locales, type Locale, withLocale } from '@/lib/i18n';

const { locale, path = '/' } = Astro.props as { locale: Locale; path?: string; label?: string };
const localeNames: Record<Locale, string> = {
  en: 'EN',
  es: 'ES',
  fr: 'FR',
  de: 'DE',
  it: 'IT',
  zh: '中文',
  ja: '日本',
};
---
<label class="sr-only" for="locale-switcher">{Astro.props.label ?? 'Language'}</label>
<select
  id="locale-switcher"
  class="locale-select"
  aria-label={Astro.props.label ?? 'Language'}
>
  {locales.map((candidate) => (
    <option value={withLocale(candidate, path)} selected={candidate === locale}>{localeNames[candidate]}</option>
  ))}
</select>

<script is:inline>
  const localeSwitcher = document.getElementById('locale-switcher');
  localeSwitcher?.addEventListener('change', (event) => {
    if (event.target instanceof HTMLSelectElement) {
      window.location.href = event.target.value;
    }
  });
</script>

# ──────────────────────────────────────────────────────────────────────────────
# DomusMind self-hosted configuration
# Copy this file to .env, then fill in every value marked REQUIRED.
# ──────────────────────────────────────────────────────────────────────────────

# Container registry hosting the images.
IMAGE_REGISTRY=ghcr.io

# Registry namespace — GitHub username or org that published the images.
IMAGE_OWNER=juangcarmona

# Image version tag to pull.
# Use a semver tag (e.g. 1.0.0) for stable releases,
# a prerelease tag (e.g. 1.1.0-alpha.1), or "edge" for the latest main build.
VERSION=edge

# ── Database ──────────────────────────────────────────────────────────────────

# REQUIRED — PostgreSQL credentials
DB_USER=domusmind
DB_PASSWORD=

# ── Authentication ────────────────────────────────────────────────────────────

# REQUIRED — Random secret used to sign JWT tokens.
# Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=

# JWT issuer claim. Change only if you need a custom issuer;
# the API and web must agree on this value.
JWT_ISSUER=domusmind

# ── Ports ─────────────────────────────────────────────────────────────────────

# Host port the DomusMind app listens on.
APP_PORT=24365

# ── First-run bootstrap admin ─────────────────────────────────────────────────
# Uncomment and fill to seed an initial admin account on first startup.
# Disable in docker-compose.yml after initial setup.
#
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# DomusMind configuration contract
#
# Copy this file to .env, then fill in every value marked REQUIRED.
# Never commit .env to source control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Deployment mode ───────────────────────────────────────────────────────────
# REQUIRED
# SingleInstance  - one household, self-hosted
# CloudHosted     - multiple households, managed deployment
DEPLOYMENT_MODE=SingleInstance

# ── Image ─────────────────────────────────────────────────────────────────────

# Container registry hosting the images.
IMAGE_REGISTRY=ghcr.io

# Registry namespace — GitHub username or org that published the images.
IMAGE_OWNER=juangcarmona

# Image version tag to pull.
# Use a semver tag (e.g. 1.0.0) for production.
# Use a prerelease tag (e.g. 1.1.0-alpha.1) for testing.
# Use "edge" for the latest main build — not for production.
VERSION=edge

# ── Database ──────────────────────────────────────────────────────────────────

# REQUIRED - PostgreSQL credentials
DB_USER=domusmind
DB_PASSWORD=

# ── Authentication ────────────────────────────────────────────────────────────

# REQUIRED - Random secret used to sign JWT tokens.
# Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=

# JWT issuer claim.
# The API and web must agree on this value.
JWT_ISSUER=domusmind

# JWT audience claim. Defaults to JWT_ISSUER if not set.
# JWT_AUDIENCE=domusmind

# ── Ports ─────────────────────────────────────────────────────────────────────

# Host port the DomusMind app listens on.
APP_PORT=24365

# ── Household provisioning policy ─────────────────────────────────────────────
# SingleInstance: AllowHouseholdCreation=true, MaxHouseholdsPerDeployment=1
# CloudHosted:    AllowHouseholdCreation=true, MaxHouseholdsPerDeployment=0 (unlimited)
#
# ALLOW_HOUSEHOLD_CREATION=true
# MAX_HOUSEHOLDS_PER_DEPLOYMENT=1
# REQUIRE_BOOTSTRAP_TOKEN=false

# ── Invitations ───────────────────────────────────────────────────────────────
# Disabled by default. Enable for CloudHosted when invite-only signup is needed.
#
# INVITATIONS_ENABLED=false
# REQUIRE_INVITATION_FOR_SIGNUP=false

# ── Email ─────────────────────────────────────────────────────────────────────
# Disabled in SingleInstance by default.
# Required for CloudHosted when invitations or notifications are enabled.
#
# EMAIL_ENABLED=false
# EMAIL_PROVIDER=

# ── Abuse protection ──────────────────────────────────────────────────────────
# Disabled by default. Enable for CloudHosted.
#
# RATE_LIMITING_ENABLED=false
# CAPTCHA_ENABLED=false
# SIGNUP_PROTECTION_LEVEL=none

# ── Observability ─────────────────────────────────────────────────────────────
# Structured logging is always on. Metrics and tracing are opt-in.
# Enable metrics and tracing for CloudHosted deployments.
#
# STRUCTURED_LOGGING_ENABLED=true
# METRICS_ENABLED=false
# TRACING_ENABLED=false

# ── First-run bootstrap admin (optional, headless fallback only) ──────────────
# The normal first-run path is the UI setup wizard served at the root URL.
# Use this block only for headless deployments (scripted provisioning, CI,
# disaster recovery) when the UI is not available.
#
# This path is DISABLED BY DEFAULT and becomes a permanent no-op once the
# system is initialized — whether by the wizard or a previous bootstrap run.
#
# To activate: uncomment the BootstrapAdmin__ lines in docker-compose.yml
# and set values below. Disable again after initialization.
#
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=
